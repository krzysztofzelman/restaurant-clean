# ── Frontend ──

# Backend API URL (used by frontend Vite build)
VITE_API_URL=http://localhost:8000

# Stripe publishable key (from Stripe Dashboard)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxx

# ── Backend (Docker reads these from .env) ──

# Database URL (Docker internal hostname)
DATABASE_URL=postgresql://restaurant:restaurant_dev@postgres:5432/restaurant

# Redis URL (Docker internal hostname)
REDIS_URL=redis://redis:6379/0

# JWT secret key (generate a long random string for production)
SECRET_KEY=dev-secret-key-change-in-production

# Stripe (test keys from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxx

# DeepSeek AI API key
DEEPSEEK_API_KEY=sk_xxxxxxxxxxxxxxx

# SMTP (password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend URL for CORS (set to production URL when deploying)
FRONTEND_URL=http://localhost:5173
